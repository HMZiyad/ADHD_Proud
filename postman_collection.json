    {
      "name": "Payment (Stripe)",
      "description": "Stripe Checkout integration.\n\nSTEP 1: POST to 'Create Checkout Session' → get session_url + order_number\nSTEP 2: Open session_url in browser → pay with test card 4242 4242 4242 4242\nSTEP 3: Stripe CLI (running in Docker stripe-cli service) fires the webhook automatically\nSTEP 4: GET the order to confirm payment_status = 'paid'\n\nTest cards:\n  Success: 4242 4242 4242 4242\n  Decline: 4000 0000 0000 0002\n  Requires auth: 4000 0025 0000 3155",
      "item": [
        {
          "name": "1. Create Checkout Session",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer <YOUR_ACCESS_TOKEN>"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"first_name\": \"Alex\",\n    \"last_name\": \"Rivera\",\n    \"email\": \"alex@example.com\",\n    \"phone\": \"+1 (555) 123-4567\",\n    \"address\": \"123 Main Street\",\n    \"city\": \"Miami\",\n    \"state\": \"Florida\",\n    \"zip_code\": \"33101\",\n    \"country\": \"USA\",\n    \"order_notes\": \"Please leave at the door.\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/orders/checkout/create-session/",
              "protocol": "http", "host": ["localhost"], "port": "8000",
              "path": ["api","orders","checkout","create-session",""]
            }
          }
        },
        {
          "name": "2. Stripe Webhook — Simulate checkout.session.completed",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Stripe-Signature", "value": "t=1234567890,v1=fake_signature_replace_or_disable_for_dev",
               "description": "Stripe CLI generates this automatically. For manual dev testing without signature, temporarily set STRIPE_WEBHOOK_SECRET to empty string in .env."}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"id\": \"evt_test_webhook\",\n    \"type\": \"checkout.session.completed\",\n    \"data\": {\n        \"object\": {\n            \"id\": \"cs_test_REPLACE_WITH_REAL_SESSION_ID\",\n            \"object\": \"checkout.session\",\n            \"payment_status\": \"paid\",\n            \"metadata\": {\n                \"order_number\": \"ORD-2026-XXXXXX\",\n                \"user_id\": \"1\"\n            }\n        }\n    }\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/orders/webhook/",
              "protocol": "http", "host": ["localhost"], "port": "8000",
              "path": ["api","orders","webhook",""]
            }
          }
        },
        {
          "name": "3. Get Order (Verify payment_status = paid)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer <YOUR_ACCESS_TOKEN>"}],
            "url": {
              "raw": "http://localhost:8000/api/orders/ORD-2026-XXXXXX/",
              "protocol": "http", "host": ["localhost"], "port": "8000",
              "path": ["api","orders","ORD-2026-XXXXXX",""]
            }
          }
        }
      ]
    }
