  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"SecurePass123!\",\n    \"confirm_password\": \"SecurePass123!\"\n}"},
            "url": {"raw": "http://localhost:8000/api/users/register/", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["api","users","register",""]}
          }
        },
        {
          "name": "Login (Get JWT Tokens)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"SecurePass123!\"\n}"},
            "url": {"raw": "http://localhost:8000/api/users/login/", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["api","users","login",""]}
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n    \"refresh\": \"<YOUR_REFRESH_TOKEN>\"\n}"},
            "url": {"raw": "http://localhost:8000/api/users/token/refresh/", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["api","users","token","refresh",""]}
          }
        }
      ]
